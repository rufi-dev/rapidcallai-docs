{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "RapidCall AI",
  "appearance": {
    "default": "dark",
    "background": {
      "decoration": "grid"
    }
  },
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#2563eb"
  },
  "api": {
    "mdx": {
      "server": "https://api.rapidcall.ai",
      "auth": {
        "method": "bearer"
      }
    },
    "playground": {
      "display": "interactive"
    }
  },
  "topbarLinks": [
    {
      "name": "Dashboard",
      "url": "https://dashboard.rapidcall.ai"
    }
  ],
  "topbarCtaButton": {
    "name": "Get Started",
    "url": "https://dashboard.rapidcall.ai/register"
  },
  "tabs": [
    {
      "name": "API Reference",
      "url": "api-reference"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "GENERAL INFORMATION",
        "pages": [
          "start",
          "who-is-it-for",
          "general-information",
          "theteam"
        ]
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/rufi-dev/rapidcallai",
    "discord": "https://discord.gg/rapidcallai"
  }
}
